# ─── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL password. Used by both docker-compose and the application.
POSTGRES_PASSWORD=changeme_pentest_db
# Async connection string (used by FastAPI via asyncpg)
DATABASE_URL=postgresql+asyncpg://pentest:changeme_pentest_db@localhost:5432/pentest
# Sync connection string (used by Celery workers and Alembic migrations)
DATABASE_URL_SYNC=postgresql://pentest:changeme_pentest_db@localhost:5432/pentest

# ─── Redis (required) ────────────────────────────────────────────────────────
# Redis password. Must match the value passed to redis-server.
REDIS_PASSWORD=changeme_redis_password
# Full Redis URL including password (used by Celery broker and pub/sub)
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# ─── Celery encryption (optional) ────────────────────────────────────────────
# Fernet key for encrypting task payloads in transit. Leave empty to disable.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CELERY_FERNET_KEY=

# ─── Flower (optional) ───────────────────────────────────────────────────────
# Basic auth credentials for the Flower Celery monitoring UI at /flower/
FLOWER_BASIC_AUTH=admin:changeme_flower

# ─── DefectDojo integration (optional) ───────────────────────────────────────
# URL and API key for syncing findings to a DefectDojo instance.
# Leave empty to skip DefectDojo integration.
DEFECTDOJO_URL=http://localhost:8080
DEFECTDOJO_API_KEY=
DOJO_DB_PASSWORD=changeme_dojo_db
DOJO_SECRET_KEY=changeme_dojo_secret

# ─── Have I Been Pwned (optional) ────────────────────────────────────────────
# API key from https://haveibeenpwned.com/API/Key -- enables credential leak checks.
# Without this key, the /credentials/check endpoint will return errors.
HIBP_API_KEY=

# ─── Metasploit RPC (optional) ───────────────────────────────────────────────
# Connection details for a running msfrpcd instance. Required for /exploits/run.
METASPLOIT_HOST=msfrpcd
METASPLOIT_PORT=55553
METASPLOIT_PASSWORD=
